# SafeStorage Transport — environment (copy to .env.local and fill in)

# ── MySQL (replaces Supabase) ───────────────────────────────────────────────
# Option A: a single connection URL. Append ?ssl=true for managed hosts.
#   MYSQL_URL=mysql://user:password@host:3306/safestoragetransport?ssl=true
#
# Option B: discrete parts (used when MYSQL_URL is not set).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=transport
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=safestoragetransport
# MYSQL_SSL=true          # "true" = verify cert; "insecure" = skip verification
# MYSQL_POOL_SIZE=10

# ── App session signing (was falling back to the Supabase key) ──────────────
SESSION_SECRET=set-a-long-random-string

# ── WhatsApp via Interakt ───────────────────────────────────────────────────
# Basic-auth key from Interakt → Settings → Developer Setup → Secret Key.
INTERAKT_API_KEY=
# INTERAKT_BASE_URL=https://api.interakt.ai
# INTERAKT_COUNTRY_CODE=+91
# INTERAKT_TEMPLATE_LANG=en
# Template names EXACTLY as approved in Interakt (defaults shown):
# INTERAKT_TPL_CUSTOMER_SLOT=ss_customer_slot
# INTERAKT_TPL_CUSTOMER_SHORTLY=ss_customer_shortly
# INTERAKT_TPL_VENDOR_ORDER=ss_vendor_order

# ── Unchanged integrations ──────────────────────────────────────────────────
# SAFESTORAGE_API_BASE=https://safestorage.in/back   # legacy admin_login source of truth
# WEBHOOK_SECRET=...                                  # booking webhook shared secret
# BLOB_READ_WRITE_TOKEN=...                           # Vercel Blob (vendor docs, offline overlay)
